  "devDependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "@playwright/test": "^1.49.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@axe-core/playwright": "^4.10.1",
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
